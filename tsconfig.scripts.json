{
  "extends": "./node_modules/gts/tsconfig-google.json",
  "compilerOptions": {
    "target": "ES2021",
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmitOnError": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "typeRoots": ["node_modules/@types"],
    "outDir": "dist-scripts"
  },
  "include": ["scripts/**/*.ts", "src/**/*.ts"],
  "exclude": ["./node_modules"]
}
